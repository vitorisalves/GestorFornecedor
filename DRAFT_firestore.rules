rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // 0. Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (The Primitives)
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper to get user data safely
    function getUser(uid) {
      return get(/databases/$(database)/documents/authorized_users/$(uid)).data;
    }
    
    function userExists(uid) {
      return exists(/databases/$(database)/documents/authorized_users/$(uid));
    }

    function isAdmin() {
      if (!isSignedIn()) return false;
      // Fallback for hardcoded admin email (must be verified)
      if (request.auth.token.email == "vitorisalves1@gmail.com" && request.auth.token.email_verified == true) return true;
      
      // If we are looking up the user in DB
      if (!userExists(request.auth.uid)) return false;
      let userData = getUser(request.auth.uid);
      return userData.role == 'admin' || userData.cpf == '05839352144';
    }

    function isApproved() {
      if (!isSignedIn()) return false;
      if (isAdmin()) return true;
      
      if (!userExists(request.auth.uid)) return false;
      return getUser(request.auth.uid).status == 'approved';
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['cpf', 'status', 'requestDate', 'role']) &&
             data.cpf is string && data.cpf.size() == 11 &&
             data.status in ['pending', 'approved', 'denied'] &&
             data.role in ['admin', 'user'] &&
             data.requestDate is string;
    }

    function isValidSupplier(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'products']) &&
             data.id is string && data.id.size() <= 100 &&
             data.name is string && data.name.size() <= 200 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.products is list && data.products.size() <= 1000;
    }

    function isValidDeliveredProduct(data) {
      return data.keys().hasAll(['id', 'name', 'supplierName', 'purchaseDate', 'delivered']) &&
             data.id is string && data.id.size() <= 150 &&
             data.name is string && data.name.size() <= 200 &&
             data.supplierName is string && data.supplierName.size() <= 200 &&
             data.purchaseDate is string &&
             data.delivered is bool;
    }

    // ===============================================================
    // Resource Rules
    // ===============================================================

    match /authorized_users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Non-admins can only list their own document or none at all (handled by query filter requirement)
      allow list: if isAdmin(); 
      
      allow create: if isSignedIn() && isValidUser(incoming()) && (
        // Self-registration: status must be pending unless they are the hardcoded admin
        (incoming().cpf != '05839352144' && incoming().status == 'pending' && incoming().role == 'user') ||
        (incoming().cpf == '05839352144' && incoming().status == 'approved' && incoming().role == 'admin') ||
        isAdmin()
      );
      
      allow update: if isAdmin() || (
        isSignedIn() && request.auth.uid == userId && 
        isValidUser(incoming()) &&
        // Self-update limited: can't change roles/status unless it's the admin CPF
        (
          (incoming().cpf == '05839352144' && incoming().status == 'approved' && incoming().role == 'admin') ||
          (incoming().status == existing().status && incoming().role == existing().role)
        )
      );
      
      allow delete: if isAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidSupplier(incoming());
      allow update: if isApproved() && isValidSupplier(incoming());
      allow delete: if isAdmin();
    }

    match /shopping_lists/{listId} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /categories/{categoryId} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /reminders/{reminderId} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /delivered_products/{productId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidDeliveredProduct(incoming());
      allow update: if isApproved() && isValidDeliveredProduct(incoming());
      allow delete: if isApproved();
    }
  }
}
