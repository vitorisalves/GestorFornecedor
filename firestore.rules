rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // 0. Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (The Primitives)
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Helper to get user data safely
    function getUserData() {
      return get(/databases/$(database)/documents/authorized_users/$(request.auth.uid)).data;
    }
    
    function hasUserDoc() {
      return exists(/databases/$(database)/documents/authorized_users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.get('email', '') == "vitorisalves1@gmail.com" && request.auth.token.get('email_verified', false) == true) ||
        (exists(/databases/$(database)/documents/authorized_users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/authorized_users/$(request.auth.uid)).data.get('role', 'user') == 'admin' || 
          get(/databases/$(database)/documents/authorized_users/$(request.auth.uid)).data.get('cpf', '') == '05839352144'
        ))
      );
    }

    function isApproved() {
      return isSignedIn() && (
        (request.auth.token.get('email', '') == "vitorisalves1@gmail.com" && request.auth.token.get('email_verified', false) == true) ||
        (exists(/databases/$(database)/documents/authorized_users/$(request.auth.uid)))
      );
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================
    
    function isValidUser(data) {
      return data.keys().hasAll(['cpf', 'status', 'requestDate', 'role']) &&
             data.cpf is string && data.cpf.size() == 11 &&
             data.status in ['pending', 'approved', 'denied'] &&
             data.role in ['admin', 'user'] &&
             data.requestDate is string && data.requestDate.size() < 100;
    }

    function isValidSupplier(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'products']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.phone is string && data.phone.size() <= 30 &&
             data.products is list && data.products.size() <= 1000;
    }

    function isValidDeliveredProduct(data) {
      return data.keys().hasAll(['id', 'name', 'supplierName', 'purchaseDate', 'delivered']) &&
             data.id is string && data.id.size() <= 200 &&
             data.name is string && data.name.size() <= 200 &&
             data.supplierName is string && data.supplierName.size() <= 200 &&
             data.purchaseDate is string &&
             data.delivered is bool;
    }

    // ===============================================================
    // Resource Rules
    // ===============================================================

    match /authorized_users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin(); 
      
      allow create: if isSignedIn() && isValidUser(incoming()) && (
        request.auth.uid == userId && (
          // Admin CPF can create approved doc
          (incoming().cpf == '05839352144' && incoming().status == 'approved' && incoming().role == 'admin') ||
          // Others must be pending
          (incoming().status == 'pending' && incoming().role == 'user')
        ) || isAdmin()
      );
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (
          request.auth.uid == userId && 
          isValidUser(incoming()) &&
          (
            // Admin CPF can stay approved/admin
            (incoming().cpf == '05839352144' && incoming().status == 'approved' && incoming().role == 'admin') ||
            // Others can only update non-role/status fields
            (incoming().status == existing().status && incoming().role == existing().role)
          )
        )
      );
      
      allow delete: if isAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /shopping_lists/{listId} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /categories/{categoryId} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /reminders/{reminderId} {
      allow read: if isApproved();
      allow write: if isApproved();
    }

    match /delivered_products/{productId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidDeliveredProduct(incoming());
      allow update: if isApproved() && isValidDeliveredProduct(incoming());
      allow delete: if isApproved();
    }
  }
}
