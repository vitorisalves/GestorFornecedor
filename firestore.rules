rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/authorized_users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "vitorisalves1@gmail.com");
    }

    function isApproved() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/authorized_users/$(request.auth.uid)).data.status == 'approved' ||
         request.auth.token.email == "vitorisalves1@gmail.com");
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow write: if isApproved();
    }

    match /shopping_lists/{listId} {
      allow read: if isAuthenticated();
      allow write: if isApproved();
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow write: if isApproved();
    }

    match /reminders/{reminderId} {
      allow read: if isAuthenticated();
      allow write: if isApproved();
    }

    match /authorized_users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
  }
}
