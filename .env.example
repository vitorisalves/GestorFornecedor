# G_API_KEY: Required for Gemini AI API calls (Formerly GEMINI_API_KEY).
# AI Studio typically injects GEMINI_API_KEY, but this app is configured to use G_API_KEY.
G_API_KEY="MY_GEMINI_API_KEY"
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Omie API Credentials
OMIE_APP_KEY=3830837835825
OMIE_APP_SECRET=fa30baf859eaf8a1f0b1e7b209013775
OMIE_BASE_URL=https://production-manager-api.onrender.com/v1